import "core/primitives.ct"

module(Python/Builtins)
  # ## Python built-in abs and pow mapped to methods
  :Integer.abs -> Integer
    #runtime("intAbs")
  :Float.abs -> Float
    #runtime("floatAbs")
  :Integer.pow(exp -> Integer) -> Integer
    #runtime("intPow")
  :Float.pow(exp -> Float) -> Float
    #runtime("floatPow")
