annot(#noCore)
#noCore

module(Data/Primitive)
  data(Number)
  class(Boolean, [True, False])

class(Animal)

class(Fish)

class(Lizard)

every(Fish, isa= [/Animal])

every(Lizard, isa= [/Animal])

class(Mammal, [Cat, Dog], isa= [/Animal])

:Animal.weight -> Number

:Animal.fluffy -> Boolean
:Fish.fluffy = False
:Lizard.fluffy = False
:Cat.fluffy = True
:Dog.fluffy = True